/* pages/index/index.wxss — 首页样式 */

/* ========== Header ========== */
.header {
  background: linear-gradient(180deg, #8B4513 0%, #A0522D 60%, #B8754E 100%);
  padding: 40rpx 32rpx 48rpx;
  border-radius: 0 0 40rpx 40rpx;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.header-greeting {
  display: flex;
  flex-direction: column;
}

.greeting-text {
  font-size: 44rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.greeting-sub {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.header-logo {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  background-color: rgba(255, 255, 255, 0.15);
}

.header-date {
  margin-top: 24rpx;
}

.date-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* ========== 今日荐方卡片 ========== */
.daily-card {
  margin: -20rpx 24rpx 24rpx;
  background: #FDF8F0;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 24rpx rgba(139, 69, 19, 0.12);
  position: relative;
  z-index: 2;
}

.daily-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.daily-title-row {
  display: flex;
  align-items: center;
}

.daily-icon {
  font-size: 36rpx;
  margin-right: 10rpx;
}

.daily-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #8B4513;
}

.daily-more {
  font-size: 24rpx;
  color: #8D6E63;
}

.daily-formula-name {
  font-size: 40rpx;
  font-weight: 800;
  color: #3E2723;
  margin-bottom: 12rpx;
}

.daily-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.daily-usage {
  font-size: 26rpx;
  color: #5D4037;
  line-height: 1.7;
  margin-bottom: 12rpx;
}

.daily-herbs {
  font-size: 24rpx;
  color: #8D6E63;
  line-height: 1.6;
  background-color: rgba(139, 69, 19, 0.04);
  padding: 16rpx;
  border-radius: 12rpx;
}

.daily-herbs-label {
  font-weight: 600;
  color: #8B4513;
}

/* ========== 区域标题 ========== */
.section-title {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx 16rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #3E2723;
}

.section-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

/* ========== 快捷功能网格（2x2） ========== */
.quick-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 16rpx;
}

.quick-item {
  width: calc(50% - 32rpx);
  margin: 8rpx 16rpx;
  background: #FDF8F0;
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(139, 69, 19, 0.06);
  border: 1rpx solid #EFEBE9;
  transition: all 0.3s;
}

.quick-item:active {
  transform: scale(0.97);
  box-shadow: 0 2rpx 8rpx rgba(139, 69, 19, 0.1);
}

.quick-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.quick-icon {
  font-size: 48rpx;
}

.quick-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #3E2723;
  margin-bottom: 6rpx;
}

.quick-desc {
  font-size: 22rpx;
  color: #8D6E63;
}

/* ========== 次要功能列表 ========== */
.secondary-list {
  padding: 0 16rpx;
}

.secondary-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #FDF8F0;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin: 8rpx 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(139, 69, 19, 0.04);
  border: 1rpx solid #EFEBE9;
}

.secondary-item:active {
  opacity: 0.8;
}

.secondary-left {
  display: flex;
  align-items: center;
}

.secondary-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.secondary-info {
  display: flex;
  flex-direction: column;
}

.secondary-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #3E2723;
  margin-bottom: 4rpx;
}

.secondary-desc {
  font-size: 24rpx;
  color: #8D6E63;
}

.secondary-arrow {
  font-size: 36rpx;
  color: #C9B8A8;
  font-weight: 300;
}

/* ========== 底部提示 ========== */
.footer-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx 32rpx;
}

.footer-text {
  font-size: 22rpx;
  color: #B8A898;
  line-height: 1.8;
}

/* ========== 引导弹窗 ========== */
.guide-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.guide-content {
  width: 600rpx;
  background: #FDF8F0;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.guide-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #8B4513;
  margin-bottom: 32rpx;
}

.guide-body {
  width: 100%;
  margin-bottom: 32rpx;
}

.guide-step {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.guide-step-num {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #8B4513;
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.guide-step-text {
  font-size: 28rpx;
  color: #3E2723;
}

.guide-disclaimer {
  font-size: 22rpx;
  color: #C62828;
  margin-top: 20rpx;
}
