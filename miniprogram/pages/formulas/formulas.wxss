/* pages/formulas/formulas.wxss - 经方阁样式 */

.search-bar {
  background: #FDF8F0;
  margin: 16rpx 24rpx;
  border: 1px solid #E0D6CC;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #3E2723;
}

.search-clear {
  font-size: 28rpx;
  color: #B8A898;
  padding: 4rpx 8rpx;
}

.category-scroll {
  padding: 8rpx 0;
}

.category-list {
  display: flex;
  padding: 0 24rpx;
  white-space: nowrap;
}

.category-tag {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #5D4037;
  background: #FDF8F0;
  border: 1rpx solid #E0D6CC;
}

.category-active {
  background: #8B4513;
  color: #FFFFFF;
  border-color: transparent;
}

/* ========== 方剂卡片 ========== */
.formula-list {
  padding: 16rpx 24rpx;
}

.formula-card {
  background: #FDF8F0;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #EFEBE9;
}

.formula-header {
  margin-bottom: 12rpx;
}

.formula-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 4rpx;
}

.formula-name {
  font-size: 36rpx;
  font-weight: 800;
  color: #3E2723;
}

.formula-difficulty {
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.difficulty-basic {
  background: rgba(46, 125, 50, 0.1);
  color: #2E7D32;
}

.difficulty-medium {
  background: rgba(210, 105, 30, 0.1);
  color: #D2691E;
}

.difficulty-advanced {
  background: rgba(198, 40, 40, 0.1);
  color: #C62828;
}

.formula-source {
  font-size: 24rpx;
  color: #8D6E63;
}

.formula-tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
}

.formula-tags .tag {
  margin-right: 8rpx;
  margin-bottom: 8rpx;
}

.formula-usage {
  font-size: 26rpx;
  color: #5D4037;
  line-height: 1.6;
  margin-bottom: 10rpx;
}

.formula-usage-label {
  font-weight: 600;
  color: #8B4513;
}

.formula-herbs {
  font-size: 24rpx;
  color: #8D6E63;
  line-height: 1.6;
  background: rgba(139, 69, 19, 0.03);
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
  margin-bottom: 8rpx;
}

.formula-herbs-label {
  font-weight: 600;
  color: #8B4513;
}

.formula-arrow {
  text-align: right;
  font-size: 24rpx;
  color: #C9B8A8;
}
