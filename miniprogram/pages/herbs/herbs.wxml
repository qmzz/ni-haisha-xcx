<!-- pages/herbs/herbs.wxml — 药材库页面 -->
<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <text class="search-icon">🔍</text>
    <input
      class="search-input"
      value="{{searchKeyword}}"
      placeholder="搜索药材名称、拼音或功效..."
      placeholder-style="color: #B8A898;"
      bindinput="onSearchInput"
    />
    <text wx:if="{{searchKeyword}}" class="search-clear" bindtap="clearSearch">✕</text>
  </view>

  <!-- 分类标签 -->
  <scroll-view class="category-scroll" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="category-list">
      <view
        wx:for="{{categories}}"
        wx:key="id"
        class="category-tag {{activeCategory === item.id ? 'category-active' : ''}}"
        data-category="{{item.id}}"
        bindtap="switchCategory"
      >
        {{item.name}}
      </view>
    </view>
  </scroll-view>

  <!-- 药材列表 -->
  <view class="herb-list">
    <view
      wx:for="{{herbList}}"
      wx:key="id"
      class="herb-card"
      data-id="{{item.id}}"
      bindtap="goToDetail"
    >
      <view class="herb-card-left">
        <view class="herb-avatar">
          <text class="herb-avatar-text">{{item.name[0]}}</text>
        </view>
      </view>
      <view class="herb-card-body">
        <view class="herb-card-header">
          <text class="herb-name">{{item.name}}</text>
          <text class="herb-pinyin">{{item.pinyin}}</text>
        </view>
        <view class="herb-tags">
          <text class="tag tag-primary">{{item.category}}</text>
          <text class="tag tag-default">{{item.property}}{{item.flavor}}</text>
        </view>
        <view class="herb-functions ellipsis">
          <text>{{item.functions}}</text>
        </view>
      </view>
      <view class="herb-card-right">
        <text class="herb-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 加载更多 -->
  <view wx:if="{{loading}}" class="loading-more">
    <text>加载中...</text>
  </view>

  <!-- 没有更多 -->
  <view wx:if="{{!hasMore && herbList.length > 0}}" class="loading-more">
    <text>— 已加载全部 —</text>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{herbList.length === 0 && !loading}}" class="empty-state">
    <text class="empty-icon">🌿</text>
    <text class="empty-text">未找到匹配的药材</text>
    <text class="empty-text text-sm text-muted">试试其他关键词或分类</text>
  </view>
</view>
