<!-- pages/cases/cases.wxml — 医案馆页面 -->
<view class="container">
  <!-- 分类标签 -->
  <scroll-view class="category-scroll" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="category-list">
      <view
        wx:for="{{categories}}"
        wx:key="id"
        class="category-tag {{activeCategory === item.id ? 'category-active' : ''}}"
        data-category="{{item.id}}"
        bindtap="switchCategory"
      >
        {{item.name}}
      </view>
    </view>
  </scroll-view>

  <!-- 医案列表 -->
  <view class="case-list">
    <view
      wx:for="{{caseList}}"
      wx:key="id"
      class="case-card"
    >
      <view class="case-header" data-id="{{item.id}}" bindtap="toggleDetail">
        <view class="case-title-row">
          <text class="case-title">{{item.title}}</text>
          <text class="case-expand-icon">{{item.expanded ? '▾' : '▸'}}</text>
        </view>
        <view class="case-meta">
          <text class="tag tag-primary">{{item.category}}</text>
          <text class="case-source">{{item.source}} · {{item.doctor}}</text>
        </view>
        <view class="case-summary">
          <text>{{item.summary}}</text>
        </view>
      </view>

      <!-- 展开详情 -->
      <view wx:if="{{item.expanded}}" class="case-detail">
        <view class="case-detail-item">
          <text class="case-detail-label">📋 症状</text>
          <text class="case-detail-text">{{item.details.symptoms}}</text>
        </view>
        <view class="case-detail-item">
          <text class="case-detail-label">🩺 诊断</text>
          <text class="case-detail-text text-primary font-bold">{{item.details.diagnosis}}</text>
        </view>
        <view class="case-detail-item">
          <text class="case-detail-label">🌿 方药</text>
          <text class="case-detail-text">{{item.details.formula}}</text>
        </view>
        <view class="case-detail-item">
          <text class="case-detail-label">✅ 效果</text>
          <text class="case-detail-text text-success">{{item.details.result}}</text>
        </view>
        <view class="case-detail-item">
          <text class="case-detail-label">📖 按语</text>
          <text class="case-detail-text case-analysis">{{item.details.analysis}}</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{caseList.length === 0}}" class="empty-state">
    <text class="empty-icon">📋</text>
    <text class="empty-text">暂无此类医案</text>
  </view>
</view>
