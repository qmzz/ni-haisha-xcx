/* pages/formula-detail/formula-detail.wxss - 方剂详情样式 */

/* ========== 头部卡片 ========== */
.formula-header-card {
  margin: 0 0 16rpx;
}

.formula-header-bg {
  background: linear-gradient(135deg, #6B3410, #8B4513);
  padding: 40rpx 32rpx;
}

.formula-header-name {
  font-size: 48rpx;
  font-weight: 800;
  color: #FFFFFF;
  display: block;
  margin-bottom: 12rpx;
}

.formula-header-meta {
  display: flex;
  align-items: center;
  /* gap:16rpx; */
  margin-bottom: 16rpx;
}

.formula-header-source {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 600;
}

.formula-header-author {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.formula-header-tags {
  display: flex;
}

/* ========== 区域卡片 ========== */
.section-card {
  background: #FDF8F0;
  margin: 16rpx 24rpx;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(139, 69, 19, 0.04);
  border: 1rpx solid #EFEBE9;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #EFEBE9;
}

.section-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #5D4037;
}

.section-content {
  font-size: 28rpx;
  color: #3E2723;
  line-height: 1.8;
}

/* ========== 组成药材 ========== */
.herb-composition {
  display: flex;
  flex-direction: column;
  /* gap:16rpx; */
}

.herb-composition-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx;
  background: rgba(139, 69, 19, 0.03);
  border-radius: 12rpx;
  border: 1rpx solid #EFEBE9;
}

.herb-composition-item:active {
  opacity: 0.8;
  background: rgba(139, 69, 19, 0.06);
}

.herb-comp-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #6B3410, #8B4513);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.herb-comp-avatar-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.herb-comp-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.herb-comp-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #3E2723;
  margin-bottom: 4rpx;
}

.herb-comp-dosage {
  font-size: 24rpx;
  color: #8B4513;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.herb-comp-note {
  font-size: 24rpx;
  color: #8D6E63;
  line-height: 1.5;
}

/* ========== 相关方剂 ========== */
.related-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #EFEBE9;
}

.related-item:last-child {
  border-bottom: none;
}

.related-item:active {
  opacity: 0.8;
}

.related-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #3E2723;
}

.text-danger {
  color: #C62828 !important;
}
