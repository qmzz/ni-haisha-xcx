/* pages/chat/chat.wxss — AI 对话页样式 */

.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #F5F0E8;
}

.chat-scroll {
  flex: 1;
  padding: 16rpx 0;
}

.chat-list {
  padding: 0 24rpx;
}

/* ========== 消息行 ========== */
.msg-wrapper {
  display: flex;
  margin-bottom: 24rpx;
  align-items: flex-start;
}

.msg-user {
  flex-direction: row-reverse;
}

.msg-ai {
  flex-direction: row;
}

.msg-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #FDF8F0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin: 0 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(139, 69, 19, 0.08);
}

.avatar-icon {
  font-size: 36rpx;
}

.msg-body {
  max-width: 480rpx;
}

.msg-body-user {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.msg-body-ai {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

/* 系统消息 */
.msg-system {
  background: linear-gradient(135deg, #FDF8F0, #F5F0E8);
  border: 1rpx solid #D7CCC8;
  border-radius: 16rpx;
  padding: 24rpx;
  max-width: 560rpx;
}

.msg-system-text {
  font-size: 28rpx;
  color: #3E2723;
  line-height: 1.8;
  white-space: pre-line;
}

/* AI 消息气泡 */
.msg-content-ai {
  background: #FFFFFF;
  border-radius: 20rpx 20rpx 20rpx 4rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(139, 69, 19, 0.06);
  border: 1rpx solid #EFEBE9;
}

.msg-content-ai .msg-text {
  color: #3E2723;
  font-size: 28rpx;
  line-height: 1.7;
  white-space: pre-line;
}

/* 用户消息气泡 */
.msg-content-user {
  background: linear-gradient(135deg, #8B4513, #A0522D);
  border-radius: 20rpx 20rpx 4rpx 20rpx;
  padding: 20rpx 24rpx;
}

.msg-content-user .msg-text {
  color: #FFFFFF;
  font-size: 28rpx;
  line-height: 1.7;
  white-space: pre-line;
}

.msg-time {
  font-size: 20rpx;
  color: #B8A898;
  margin-top: 8rpx;
  padding: 0 4rpx;
}

/* ========== AI 思考动画 ========== */
.msg-thinking {
  background: #FFFFFF;
  border-radius: 20rpx 20rpx 20rpx 4rpx;
  padding: 20rpx 28rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(139, 69, 19, 0.06);
  border: 1rpx solid #EFEBE9;
}

.thinking-dot {
  font-size: 16rpx;
  color: #8B4513;
  margin-right: 6rpx;
  animation: thinking 1.4s infinite;
}

.thinking-dot:nth-child(2) { animation-delay: 0.2s; }
.thinking-dot:nth-child(3) { animation-delay: 0.4s; }

.thinking-text {
  font-size: 24rpx;
  color: #8D6E63;
  margin-left: 8rpx;
}

@keyframes thinking {
  0%, 80%, 100% { opacity: 0.3; }
  40% { opacity: 1; }
}

/* ========== 底部输入区域 ========== */
.input-area {
  background: #FDF8F0;
  border-top: 1rpx solid #EFEBE9;
  padding: 16rpx 24rpx;
}

.input-row {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
}

.chat-input {
  flex: 1;
  background: #FFFFFF;
  border-radius: 24rpx;
  border: 1rpx solid #E0D6CC;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  line-height: 1.5;
  max-height: 180rpx;
  color: #3E2723;
  width: 100%;
}

.send-btn {
  background: #D7CCC8;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  padding: 16rpx 28rpx;
  border-radius: 24rpx;
  white-space: nowrap;
}

.send-active {
  background: linear-gradient(135deg, #8B4513, #A0522D);
}

.input-actions {
  display: flex;
  justify-content: center;
  padding-top: 8rpx;
}

.action-link {
  font-size: 22rpx;
  color: #B8A898;
}

.action-link:active {
  color: #8B4513;
}
