<!-- pages/chat/chat.wxml — AI 对话页面 -->
<view class="chat-container">
  <!-- 聊天区域 -->
  <scroll-view
    class="chat-scroll"
    scroll-y
    scroll-into-view="{{scrollToView}}"
    scroll-with-animation="{{true}}"
    enhanced="{{true}}"
    show-scrollbar="{{false}}"
  >
    <view class="chat-list">
      <view
        wx:for="{{messages}}"
        wx:key="id"
        id="msg-{{item.id}}"
        class="msg-wrapper {{item.role === 'user' ? 'msg-user' : 'msg-ai'}}"
      >
        <view class="msg-avatar" wx:if="{{item.role !== 'user'}}">
          <text class="avatar-icon">📚</text>
        </view>

        <view class="msg-body {{item.role === 'user' ? 'msg-body-user' : 'msg-body-ai'}}">
          <view wx:if="{{item.role === 'system'}}" class="msg-system">
            <text class="msg-system-text">{{item.content}}</text>
          </view>

          <view wx:elif="{{item.role === 'assistant'}}" class="msg-content-ai">
            <text class="msg-text">{{item.content}}</text>
          </view>

          <view wx:else class="msg-content-user">
            <text class="msg-text">{{item.content}}</text>
          </view>

          <text class="msg-time">{{item.time}}</text>
        </view>

        <view class="msg-avatar" wx:if="{{item.role === 'user'}}">
          <text class="avatar-icon">👤</text>
        </view>
      </view>

      <view wx:if="{{loading}}" class="msg-wrapper msg-ai">
        <view class="msg-avatar">
          <text class="avatar-icon">📚</text>
        </view>
        <view class="msg-body msg-body-ai">
          <view class="msg-thinking">
            <text class="thinking-dot">●</text>
            <text class="thinking-dot">●</text>
            <text class="thinking-dot">●</text>
            <text class="thinking-text">思考中...</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 底部输入区域 -->
  <view class="input-area safe-bottom">
    <view class="input-row">
      <textarea
        class="chat-input"
        value="{{inputValue}}"
        placeholder="想问什么中医问题？"
        placeholder-style="color: #B8A898;"
        bindinput="onInput"
        auto-height="{{true}}"
        maxlength="-1"
        confirm-type="send"
        bindconfirm="sendMessage"
        show-confirm-bar="{{false}}"
        adjust-position="{{true}}"
      />
      <view class="send-btn {{inputValue ? 'send-active' : ''}}" bindtap="sendMessage">
        <text>发送</text>
      </view>
    </view>
    <view class="input-actions">
      <text class="action-link" bindtap="clearChat">清空对话</text>
    </view>
  </view>
</view>
