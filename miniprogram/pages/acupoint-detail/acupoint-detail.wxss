/* pages/acupoint-detail/acupoint-detail.wxss - 穴位详情样式 */

/* ========== 头部卡片 ========== */
.acupoint-header-card {
  margin: 0 0 16rpx;
}

.acupoint-header-bg {
  background: linear-gradient(135deg, #6A1B9A, #9C27B0);
  padding: 40rpx 32rpx;
}

.acupoint-header-name {
  font-size: 48rpx;
  font-weight: 800;
  color: #FFFFFF;
  display: block;
  margin-bottom: 12rpx;
}

.acupoint-header-meta {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.acupoint-header-meridian {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 600;
}

.acupoint-header-location {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  background: rgba(255, 255, 255, 0.15);
  border-radius: 8rpx;
  padding: 12rpx 20rpx;
}

/* ========== 区域卡片（复用 formula-detail 样式模式）========== */
.section-card {
  background: #FDF8F0;
  margin: 16rpx 24rpx;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(139, 69, 19, 0.04);
  border: 1rpx solid #EFEBE9;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #EFEBE9;
}

.section-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #5D4037;
}

.section-content {
  font-size: 28rpx;
  color: #3E2723;
  line-height: 1.8;
  white-space: pre-wrap;
}

/* ========== 底部提示 ========== */
.footer-tip {
  margin: 24rpx 24rpx;
  padding: 20rpx;
  background: #FFF3E0;
  border-radius: 12rpx;
  border: 1rpx solid #FFE0B2;
  text-align: center;
}

.footer-text {
  font-size: 24rpx;
  color: #E65100;
}
